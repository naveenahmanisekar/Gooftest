{
  "name": "goof",
  "version": "1.0.1",
  "description": "A vulnerable todo demo application",
  "homepage": "https://snyk.io/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snyk/snyk-todo-list-demo-app/"
  },
  "scripts": {
    "start": "node app.js",
    "build": "browserify -r jquery > public/js/bundle.js",
    "cleanup": "mongo express-todo --eval 'db.todos.remove({});'",
    "snyk-protect": "snyk-protect",
    "prepare": "npm run snyk-protect"
  },
  "engines": {
    "node": "6.14.1"
  },
  "dependencies": {
    "@snyk/nodejs-runtime-agent": "^1.47.3",
    "adm-zip": "0.5.2",
    "body-parser": "1.20.3",
    "cfenv": "^1.0.4",
    "consolidate": "0.14.5",
    "cookie-parser": "1.4.7",
    "dustjs-helpers": "1.5.0",
    "dustjs-linkedin": "2.7.5",
    "ejs": "2.5.5",
    "ejs-locals": "1.0.2",
    "errorhandler": "1.5.0",
    "express": "4.21.1",
    "express-fileupload": "1.1.10",
    "file-type": "^8.1.0",
    "humanize-ms": "1.2.1",
    "jquery": "^3.0.0",
    "lodash": "4.17.4",
    "marked": "1.1.1",
    "method-override": "latest",
    "moment": "2.29.2",
    "mongoose": "6.13.5",
    "morgan": "latest",
    "ms": "^2.0.0",
    "npmconf": "0.0.24",
    "optional": "^0.1.3",
    "st": "1.2.1",
    "stream-buffers": "^3.0.1",
    "tap": "^18.0.0",
    "@snyk/protect": "latest"
  },
  "devDependencies": {
    "browserify": "^13.1.1"
  },
  "snyk": true
}
